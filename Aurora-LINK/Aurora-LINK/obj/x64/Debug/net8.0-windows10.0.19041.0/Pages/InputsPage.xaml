<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="Aurora_LINK.Pages.InputsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Aurora_LINK.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <local:TriggerDisplayConverter x:Key="TriggerDisplay" />
        <local:ActionDisplayConverter  x:Key="ActionDisplay" />
        <local:BoolToOpacityConverter  x:Key="BoolToOpacity" />
    </Page.Resources>

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="Entrées"
                   FontSize="28"
                   FontWeight="SemiBold" />

        <!-- Liste des 10 entrées -->
        <ListView x:ConnectionId='2' Grid.Row="1" Grid.Column="0"
                  x:Name="InputsList"
                                                         
                                                                              
                  SelectionMode="Single"
                  Margin="0,0,16,0">
            <ListView.ItemTemplate>
                <DataTemplate                                      >
                    <Grid x:ConnectionId='18' Padding="8,10" ColumnSpacing="12"
                                                                                                             >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:ConnectionId='19' Grid.Column="0"
                                                              
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   VerticalAlignment="Center" />
                        <TextBlock x:ConnectionId='20' Grid.Column="1"
                                                                          
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <FontIcon x:ConnectionId='21' Grid.Column="2"
                                  Glyph="&#xE73E;"
                                  FontSize="14"
                                  Foreground="{ThemeResource SystemAccentColor}"
                                                                               />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Panneau de détail -->
        <ScrollViewer Grid.Row="1" Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="8,0,0,0">

            <StackPanel x:ConnectionId='3' Spacing="16"
                                                                                 
                        MaxWidth="480"
                        HorizontalAlignment="Left">

                <!-- En-tête entrée sélectionnée -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock x:ConnectionId='15' FontSize="22" FontWeight="SemiBold"
                                                                                                />
                    <ToggleSwitch x:ConnectionId='16' x:Name="EnableToggle"
                                  OnContent="Activée" OffContent="Désactivée"
                                                                                                
                                  VerticalAlignment="Center" />
                </StackPanel>

                <!-- Déclencheur -->
                <ComboBox x:ConnectionId='4' x:Name="TriggerCombo"
                          Header="Déclencheur"
                          HorizontalAlignment="Stretch"
                                                                        
                                                                                              
                                                                                             >
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource TriggerDisplay}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Action -->
                <ComboBox x:ConnectionId='5' x:Name="ActionCombo"
                          Header="Action"
                          HorizontalAlignment="Stretch"
                                                                       
                                                                                             
                                                                                             >
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource ActionDisplay}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Cible (visible si LoadScene ou SetBright) -->
                <NumberBox x:ConnectionId='6' x:Name="TargetBox"
                                                                                             
                           Minimum="0" Maximum="255"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="1"
                                                                                       
                                                                                                
                                                                                              
                           HorizontalAlignment="Stretch" />

                <!-- Paramètre (visible si DimUp/DimDown/SetBright/LongPress) -->
                <NumberBox x:ConnectionId='7' x:Name="ParamBox"
                                                                                            
                           Minimum="0" Maximum="65535"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="1"
                                                                                      
                                                                                               
                                                                                              
                           HorizontalAlignment="Stretch" />

                <!-- Priorité -->
                <NumberBox x:ConnectionId='8' Header="Priorité (0 = plus haute)"
                           Minimum="0" Maximum="255"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="1"
                                                                                         
                                                                                              
                           HorizontalAlignment="Stretch" />

                <!-- Anti-rebond -->
                <NumberBox x:ConnectionId='9' Header="Anti-rebond (ms)"
                           Minimum="0" Maximum="65535"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="5"
                                                                                           
                                                                                              
                           HorizontalAlignment="Stretch" />

                <!-- Résumé de la règle -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Résumé de la règle"
                                   FontWeight="SemiBold"
                                   FontSize="14" />
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="13">
                            <Run Text="Quand " />
                            <Run x:ConnectionId='10'                                                                 
                                 FontWeight="SemiBold" />
                            <Run Text=" détecte " />
                            <Run x:ConnectionId='11'                                                            
                                                                                    />
                            <Run Text=" → " />
                            <Run x:ConnectionId='12'                                                           
                                                                                  
                                 FontWeight="SemiBold" />
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>

