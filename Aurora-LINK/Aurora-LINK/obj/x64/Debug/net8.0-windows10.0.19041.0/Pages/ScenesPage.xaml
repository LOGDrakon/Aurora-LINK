<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="Aurora_LINK.Pages.ScenesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Aurora_LINK.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <local:LedModeDisplayConverter x:Key="LedModeDisplay" />
        <local:BoolToOpacityConverter  x:Key="BoolToOpacity" />
    </Page.Resources>

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Titre + boutons -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" Spacing="16">
            <TextBlock Text="Scènes"
                       FontSize="28"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Button x:ConnectionId='23' Content="Ajouter"
                                      
                                                                      
                    VerticalAlignment="Center" />
            <Button x:ConnectionId='24' Content="Supprimer"
                                         
                                                                            
                    VerticalAlignment="Center" />
        </StackPanel>

        <!-- Liste des scènes -->
        <ListView x:ConnectionId='2' Grid.Row="1" Grid.Column="0"
                  x:Name="ScenesList"
                                                         
                                                                              
                  SelectionMode="Single"
                  Margin="0,0,16,0">
            <ListView.ItemTemplate>
                <DataTemplate                                  >
                    <Grid x:ConnectionId='19' Padding="8,10" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:ConnectionId='20' Grid.Column="0"
                                                                           
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   VerticalAlignment="Center" />
                        <TextBlock x:ConnectionId='21' Grid.Column="1"
                                                                               
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <FontIcon x:ConnectionId='22' Grid.Column="2"
                                  Glyph="&#xE768;"
                                  FontSize="14"
                                  Foreground="{ThemeResource SystemAccentColor}"
                                                                               />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Panneau de détail -->
        <ScrollViewer Grid.Row="1" Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="8,0,0,0">

            <StackPanel x:ConnectionId='3' Spacing="16"
                                                                                 
                        MaxWidth="480"
                        HorizontalAlignment="Left">

                <!-- En-tête -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock x:ConnectionId='16' FontSize="22" FontWeight="SemiBold"
                                                                                                />
                    <ToggleSwitch x:ConnectionId='17' OnContent="Auto-start" OffContent="Manuel"
                                                                                                
                                  VerticalAlignment="Center" />
                </StackPanel>

                <!-- Mode LED -->
                <ComboBox x:ConnectionId='4' Header="Mode"
                          HorizontalAlignment="Stretch"
                                                                        
                                                                                           >
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource LedModeDisplay}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Couleur RGB -->
                <StackPanel x:ConnectionId='5' Spacing="8"
                                                                                                >
                    <TextBlock Text="Couleur" FontSize="14" />

                    <!-- Aperçu couleur -->
                    <Border Height="32" CornerRadius="6"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            HorizontalAlignment="Stretch">
                        <Border.Background>
                            <SolidColorBrush x:ConnectionId='14'                                                                    />
                        </Border.Background>
                    </Border>

                    <!-- Rouge -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="Rouge" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Slider x:ConnectionId='13' Minimum="0" Maximum="255"
                                                                                         
                                StepFrequency="1" />
                    </StackPanel>

                    <!-- Vert -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="Vert" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Slider x:ConnectionId='12' Minimum="0" Maximum="255"
                                                                                           
                                StepFrequency="1" />
                    </StackPanel>

                    <!-- Bleu -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="Bleu" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Slider x:ConnectionId='11' Minimum="0" Maximum="255"
                                                                                          
                                StepFrequency="1" />
                    </StackPanel>
                </StackPanel>

                <!-- Durée ON / montée / flash -->
                <NumberBox x:ConnectionId='6'                                                                
                           Minimum="0" Maximum="65535"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="10"
                                                                                      
                                                                                             
                           HorizontalAlignment="Stretch" />

                <!-- Durée OFF / descente / pause -->
                <NumberBox x:ConnectionId='7'                                                                 
                           Minimum="0" Maximum="65535"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="10"
                                                                                       
                                                                                              
                           HorizontalAlignment="Stretch" />

                <!-- Répétitions -->
                <NumberBox x:ConnectionId='8'                                                                   
                           Minimum="0" Maximum="255"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="1"
                                                                                       
                                                                                                
                           HorizontalAlignment="Stretch" />

                <!-- Fondu -->
                <NumberBox x:ConnectionId='9'                                                                     
                           Minimum="0" Maximum="255"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="1"
                                                                                         
                                                                                                  
                           HorizontalAlignment="Stretch" />

                <!-- Résumé -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Résumé"
                                   FontWeight="SemiBold"
                                   FontSize="14" />
                        <TextBlock x:ConnectionId='10'                                                                 
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="13" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>

