<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Aurora_LINK.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Aurora_LINK"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Aurora-LINK">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <NavigationView x:ConnectionId='2'
            x:Name="NavView"
            Grid.Column="0"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneToggleButtonVisible="True"
            PaneDisplayMode="Left"
            OpenPaneLength="220"
                                                       >

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Tableau de bord" Tag="Dashboard">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Entrées" Tag="Inputs">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Scènes" Tag="Scenes">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Pictures" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Système" Tag="System">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Setting" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
        </NavigationView>

        <!-- Zone principale -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Barre d'outils projet -->
            <CommandBar Grid.Row="0"
                        DefaultLabelPosition="Right"
                        Background="Transparent"
                        IsOpen="False">
                <AppBarButton x:ConnectionId='6' x:Name="BtnNew" Icon="Page2" Label="Nouveau"
                                                   />
                <AppBarButton x:ConnectionId='7' x:Name="BtnOpen" Icon="OpenFile" Label="Ouvrir"
                                                    />
                <AppBarButton x:ConnectionId='8' x:Name="BtnSave" Icon="Save" Label="Enregistrer"
                                                    />
                <AppBarButton x:ConnectionId='9' x:Name="BtnSaveAs" Label="Enregistrer sous…"
                                                     >
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE792;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator />
                <AppBarButton x:ConnectionId='10' x:Name="BtnExportFlora" Label="Exporter .flora"
                                                          >
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xEDE1;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:ConnectionId='11' x:Name="BtnImportFlora" Label="Importer .flora"
                                                          >
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE150;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator />
                <AppBarButton x:ConnectionId='12' x:Name="BtnUpload" Label="Téléverser"
                                                     >
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE898;" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </CommandBar>

            <Frame x:ConnectionId='3' x:Name="ContentFrame" Grid.Row="1" />

            <Border Grid.Row="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:ConnectionId='4' x:Name="ConnectionStatus"
                               Grid.Column="0"
                               Text="Non connecté"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock x:ConnectionId='5' x:Name="ProjectStatus"
                               Grid.Column="1"
                               Text="Nouveau projet"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

