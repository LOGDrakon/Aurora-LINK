<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Aurora_LINK.Pages.ScenesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Aurora_LINK.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <local:LedModeDisplayConverter x:Key="LedModeDisplay" />
        <local:BoolToOpacityConverter  x:Key="BoolToOpacity" />
    </Page.Resources>

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Titre + boutons -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" Spacing="16">
            <TextBlock Text="Scènes"
                       FontSize="28"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Button Content="Ajouter"
                    Click="OnAddScene"
                    IsEnabled="{x:Bind ViewModel.CanAdd, Mode=OneWay}"
                    VerticalAlignment="Center" />
            <Button Content="Supprimer"
                    Click="OnRemoveScene"
                    IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}"
                    VerticalAlignment="Center" />
        </StackPanel>

        <!-- Liste des scènes -->
        <ListView Grid.Row="1" Grid.Column="0"
                  x:Name="ScenesList"
                  ItemsSource="{x:Bind ViewModel.Scenes}"
                  SelectedItem="{x:Bind ViewModel.SelectedScene, Mode=TwoWay}"
                  SelectionMode="Single"
                  Margin="0,0,16,0">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:SceneViewModel">
                    <Grid Padding="8,10" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{x:Bind DisplayName, Mode=OneWay}"
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind ModeDisplayName, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <FontIcon Grid.Column="2"
                                  Glyph="&#xE768;"
                                  FontSize="14"
                                  Foreground="{ThemeResource SystemAccentColor}"
                                  Visibility="{x:Bind AutoStart, Mode=OneWay}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Panneau de détail -->
        <ScrollViewer Grid.Row="1" Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="8,0,0,0">

            <StackPanel Spacing="16"
                        Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay}"
                        MaxWidth="480"
                        HorizontalAlignment="Left">

                <!-- En-tête -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock FontSize="22" FontWeight="SemiBold"
                               Text="{x:Bind ViewModel.SelectedScene.DisplayName, Mode=OneWay}" />
                    <ToggleSwitch OnContent="Auto-start" OffContent="Manuel"
                                  IsOn="{x:Bind ViewModel.SelectedScene.AutoStart, Mode=TwoWay}"
                                  VerticalAlignment="Center" />
                </StackPanel>

                <!-- Mode LED -->
                <ComboBox Header="Mode"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{x:Bind ViewModel.LedModeValues}"
                          SelectedItem="{x:Bind ViewModel.SelectedScene.Mode, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource LedModeDisplay}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Couleur RGB -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.SelectedScene.ShowColor, Mode=OneWay}">
                    <TextBlock Text="Couleur" FontSize="14" />

                    <!-- Aperçu couleur -->
                    <Border Height="32" CornerRadius="6"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            HorizontalAlignment="Stretch">
                        <Border.Background>
                            <SolidColorBrush Color="{x:Bind ViewModel.SelectedScene.PreviewColor, Mode=OneWay}" />
                        </Border.Background>
                    </Border>

                    <!-- Rouge -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="Rouge" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Slider Minimum="0" Maximum="255"
                                Value="{x:Bind ViewModel.SelectedScene.Red, Mode=TwoWay}"
                                StepFrequency="1" />
                    </StackPanel>

                    <!-- Vert -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="Vert" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Slider Minimum="0" Maximum="255"
                                Value="{x:Bind ViewModel.SelectedScene.Green, Mode=TwoWay}"
                                StepFrequency="1" />
                    </StackPanel>

                    <!-- Bleu -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="Bleu" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Slider Minimum="0" Maximum="255"
                                Value="{x:Bind ViewModel.SelectedScene.Blue, Mode=TwoWay}"
                                StepFrequency="1" />
                    </StackPanel>
                </StackPanel>

                <!-- Durée ON / montée / flash -->
                <NumberBox Header="{x:Bind ViewModel.SelectedScene.TOnLabel, Mode=OneWay}"
                           Minimum="0" Maximum="65535"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="10"
                           Value="{x:Bind ViewModel.SelectedScene.TOnMs, Mode=TwoWay}"
                           Visibility="{x:Bind ViewModel.SelectedScene.ShowTOn, Mode=OneWay}"
                           HorizontalAlignment="Stretch" />

                <!-- Durée OFF / descente / pause -->
                <NumberBox Header="{x:Bind ViewModel.SelectedScene.TOffLabel, Mode=OneWay}"
                           Minimum="0" Maximum="65535"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="10"
                           Value="{x:Bind ViewModel.SelectedScene.TOffMs, Mode=TwoWay}"
                           Visibility="{x:Bind ViewModel.SelectedScene.ShowTOff, Mode=OneWay}"
                           HorizontalAlignment="Stretch" />

                <!-- Répétitions -->
                <NumberBox Header="{x:Bind ViewModel.SelectedScene.RepeatLabel, Mode=OneWay}"
                           Minimum="0" Maximum="255"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="1"
                           Value="{x:Bind ViewModel.SelectedScene.Repeat, Mode=TwoWay}"
                           Visibility="{x:Bind ViewModel.SelectedScene.ShowRepeat, Mode=OneWay}"
                           HorizontalAlignment="Stretch" />

                <!-- Fondu -->
                <NumberBox Header="{x:Bind ViewModel.SelectedScene.FadeTimeLabel, Mode=OneWay}"
                           Minimum="0" Maximum="255"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="1"
                           Value="{x:Bind ViewModel.SelectedScene.FadeTime, Mode=TwoWay}"
                           Visibility="{x:Bind ViewModel.SelectedScene.ShowFadeTime, Mode=OneWay}"
                           HorizontalAlignment="Stretch" />

                <!-- Résumé -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Résumé"
                                   FontWeight="SemiBold"
                                   FontSize="14" />
                        <TextBlock Text="{x:Bind ViewModel.SelectedScene.SummaryText, Mode=OneWay}"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="13" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
