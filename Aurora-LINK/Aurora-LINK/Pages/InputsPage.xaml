<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Aurora_LINK.Pages.InputsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Aurora_LINK.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <local:TriggerDisplayConverter x:Key="TriggerDisplay" />
        <local:ActionDisplayConverter  x:Key="ActionDisplay" />
        <local:BoolToOpacityConverter  x:Key="BoolToOpacity" />
    </Page.Resources>

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="Entrées"
                   FontSize="28"
                   FontWeight="SemiBold" />

        <!-- Liste des 10 entrées -->
        <ListView Grid.Row="1" Grid.Column="0"
                  x:Name="InputsList"
                  ItemsSource="{x:Bind ViewModel.Inputs}"
                  SelectedItem="{x:Bind ViewModel.SelectedInput, Mode=TwoWay}"
                  SelectionMode="Single"
                  Margin="0,0,16,0">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:InputRuleViewModel">
                    <Grid Padding="8,10" ColumnSpacing="12"
                          Opacity="{x:Bind IsEnabled, Mode=OneWay, Converter={StaticResource BoolToOpacity}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{x:Bind DisplayName}"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind StatusText, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <FontIcon Grid.Column="2"
                                  Glyph="&#xE73E;"
                                  FontSize="14"
                                  Foreground="{ThemeResource SystemAccentColor}"
                                  Visibility="{x:Bind IsEnabled, Mode=OneWay}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Panneau de détail -->
        <ScrollViewer Grid.Row="1" Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="8,0,0,0">

            <StackPanel Spacing="16"
                        Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay}"
                        MaxWidth="480"
                        HorizontalAlignment="Left">

                <!-- En-tête entrée sélectionnée -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock FontSize="22" FontWeight="SemiBold"
                               Text="{x:Bind ViewModel.SelectedInput.DisplayName, Mode=OneWay}" />
                    <ToggleSwitch x:Name="EnableToggle"
                                  OnContent="Activée" OffContent="Désactivée"
                                  IsOn="{x:Bind ViewModel.SelectedInput.IsEnabled, Mode=TwoWay}"
                                  VerticalAlignment="Center" />
                </StackPanel>

                <!-- Déclencheur -->
                <ComboBox x:Name="TriggerCombo"
                          Header="Déclencheur"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{x:Bind ViewModel.TriggerValues}"
                          SelectedItem="{x:Bind ViewModel.SelectedInput.Trigger, Mode=TwoWay}"
                          IsEnabled="{x:Bind ViewModel.SelectedInput.IsEnabled, Mode=OneWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource TriggerDisplay}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Action -->
                <ComboBox x:Name="ActionCombo"
                          Header="Action"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{x:Bind ViewModel.ActionValues}"
                          SelectedItem="{x:Bind ViewModel.SelectedInput.Action, Mode=TwoWay}"
                          IsEnabled="{x:Bind ViewModel.SelectedInput.IsEnabled, Mode=OneWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource ActionDisplay}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Cible (visible si LoadScene ou SetBright) -->
                <NumberBox x:Name="TargetBox"
                           Header="{x:Bind ViewModel.SelectedInput.TargetLabel, Mode=OneWay}"
                           Minimum="0" Maximum="255"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="1"
                           Value="{x:Bind ViewModel.SelectedInput.Target, Mode=TwoWay}"
                           Visibility="{x:Bind ViewModel.SelectedInput.ShowTarget, Mode=OneWay}"
                           IsEnabled="{x:Bind ViewModel.SelectedInput.IsEnabled, Mode=OneWay}"
                           HorizontalAlignment="Stretch" />

                <!-- Paramètre (visible si DimUp/DimDown/SetBright/LongPress) -->
                <NumberBox x:Name="ParamBox"
                           Header="{x:Bind ViewModel.SelectedInput.ParamLabel, Mode=OneWay}"
                           Minimum="0" Maximum="65535"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="1"
                           Value="{x:Bind ViewModel.SelectedInput.Param, Mode=TwoWay}"
                           Visibility="{x:Bind ViewModel.SelectedInput.ShowParam, Mode=OneWay}"
                           IsEnabled="{x:Bind ViewModel.SelectedInput.IsEnabled, Mode=OneWay}"
                           HorizontalAlignment="Stretch" />

                <!-- Priorité -->
                <NumberBox Header="Priorité (0 = plus haute)"
                           Minimum="0" Maximum="255"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="1"
                           Value="{x:Bind ViewModel.SelectedInput.Priority, Mode=TwoWay}"
                           IsEnabled="{x:Bind ViewModel.SelectedInput.IsEnabled, Mode=OneWay}"
                           HorizontalAlignment="Stretch" />

                <!-- Anti-rebond -->
                <NumberBox Header="Anti-rebond (ms)"
                           Minimum="0" Maximum="65535"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="5"
                           Value="{x:Bind ViewModel.SelectedInput.DebounceMs, Mode=TwoWay}"
                           IsEnabled="{x:Bind ViewModel.SelectedInput.IsEnabled, Mode=OneWay}"
                           HorizontalAlignment="Stretch" />

                <!-- Résumé de la règle -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Résumé de la règle"
                                   FontWeight="SemiBold"
                                   FontSize="14" />
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="13">
                            <Run Text="Quand " />
                            <Run Text="{x:Bind ViewModel.SelectedInput.DisplayName, Mode=OneWay}"
                                 FontWeight="SemiBold" />
                            <Run Text=" détecte " />
                            <Run Text="{x:Bind ViewModel.SelectedInput.Trigger, Mode=OneWay,
                                        Converter={StaticResource TriggerDisplay}}" />
                            <Run Text=" → " />
                            <Run Text="{x:Bind ViewModel.SelectedInput.Action, Mode=OneWay,
                                        Converter={StaticResource ActionDisplay}}"
                                 FontWeight="SemiBold" />
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
